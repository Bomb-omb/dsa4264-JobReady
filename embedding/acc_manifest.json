{
  "model_name": "zeroentropy/zembed-1",
  "device": "cuda",
  "torch_dtype": "bfloat16",
  "normalize_embeddings": true,
  "embedding_dimension": 2560,
  "inputs": {
    "jobs_file": "data\\acc\\audit_tax_accounting_jobs.csv",
    "courses_file": "data\\2025-2026_module_clean_with_prereq_skillsfuture.csv",
    "skills_file": "data\\acc\\skills_taxo_acc.csv"
  },
  "filters": {
    "course_code_prefix": "ACC"
  },
  "splits": {
    "labels": [
      "train",
      "val",
      "test"
    ],
    "ratios": [
      0.6,
      0.2,
      0.2
    ],
    "seed": 42,
    "jobs": {
      "train": 59,
      "val": 19,
      "test": 20
    },
    "courses": {
      "train": 38,
      "val": 13,
      "test": 13
    }
  },
  "outputs": {
    "skills": "embedding\\acc_skills_embeddings.jsonl",
    "jobs_splits": {
      "train": "embedding\\jobs_train_embeddings.jsonl",
      "val": "embedding\\jobs_val_embeddings.jsonl",
      "test": "embedding\\jobs_test_embeddings.jsonl"
    },
    "courses_splits": {
      "train": "embedding\\courses_train_embeddings.jsonl",
      "val": "embedding\\courses_val_embeddings.jsonl",
      "test": "embedding\\courses_test_embeddings.jsonl"
    }
  },
  "counts": {
    "jobs": 98,
    "skills": 229,
    "courses": 64
  }
}